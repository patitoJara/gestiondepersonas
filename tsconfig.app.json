{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": []
  },
  "files": ["src/main.ts"],
  "include": [
    "src/**/*.ts",
    "src/**/*.html",
    "src/**/*.scss",
    "src/**/*.d.ts"
  ],
  "exclude": ["src/**/*.spec.ts"],
  "angularCompilerOptions": {
    "strictTemplates": true,
    "enableIvy": true
  }
}
